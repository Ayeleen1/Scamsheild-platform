{
  "manifest_version": 3,
  "name": "ScamShield Social Guard",
  "version": "0.1.0",
  "description": "Blocks suspicious links on social media using ScamShield AI backend.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "https://*.tiktok.com/*",
    "https://web.whatsapp.com/*",
    "https://*.x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*",
        "https://*.facebook.com/*",
        "https://*.tiktok.com/*",
        "https://web.whatsapp.com/*",
        "https://*.x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "ScamShield Social Guard"
  }
}
